{
  "name": "@mirk/store-libsql",
  "version": "0.1.1",
  "type": "module",
  "description": "libSQL / Turso source adapter for @mirk/store's async ports. KV + collection store and native-vector similarity store over one libSQL connection (remote, file:, or :memory:).",
  "license": "Apache-2.0",
  "author": "David Robinson <dr@monetise.io>",
  "keywords": [
    "storage",
    "key-value",
    "collection-store",
    "vector",
    "vector-search",
    "similarity",
    "cosine",
    "libsql",
    "turso",
    "embeddings"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nightwork-dev/mirk.git",
    "directory": "packages/store-libsql"
  },
  "homepage": "https://github.com/nightwork-dev/mirk/tree/main/packages/store-libsql#readme",
  "bugs": "https://github.com/nightwork-dev/mirk/issues",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf dist && tsup src/index.ts --format esm --dts --external @libsql/client"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@mirk/store": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "tsup": "^8.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    }
  }
}
